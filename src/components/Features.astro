---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="9" height="9" rx="1.5"/><rect x="13" y="2" width="9" height="9" rx="1.5"/><rect x="2" y="13" width="9" height="9" rx="1.5"/><rect x="13" y="13" width="9" height="9" rx="1.5"/></svg>`,
    title: 'Hierarchical IP Management',
    body: 'Organise your address space as Sections → Subnets → IP Addresses with real-time utilisation tracking. Get a clear picture of what\'s allocated, free, and reserved across every network.',
    tags: ['Subnets', 'Utilisation', 'CIDR'],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: 'Network Discovery',
    body: 'Automatically populate your address space using ICMP ping scans. Deploy remote discovery agents to scan distributed network segments without opening firewall holes back to the core.',
    tags: ['ICMP', 'Remote agents', 'Auto-populate'],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
    title: 'VRF & VLAN Management',
    body: 'Model complex multi-tenant and multi-site environments with full Virtual Routing and Forwarding support. Track VLANs alongside your IP allocations in a single unified view.',
    tags: ['VRF', 'VLAN', 'Multi-tenant'],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: 'DNS Zone Integration',
    body: 'Manage DNS zones and records alongside your IP allocations. Keep your address plan and DNS in sync without switching between multiple tools or maintaining separate systems.',
    tags: ['DNS zones', 'A records', 'Sync'],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: 'Stable REST API + Webhooks',
    body: 'The API is the primary integration surface — stable, OpenAPI-documented, and versioned. Subscribe to webhook events with replay capability for reliable integration with Terraform, Ansible, and CI pipelines.',
    tags: ['OpenAPI', 'Webhooks', 'Replay'],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Immutable Audit Log',
    body: 'Every change across your IP space is recorded and immutable. Know who changed what, when, and from where. Invaluable for compliance, incident response, and understanding how your network evolved.',
    tags: ['Change history', 'Compliance', 'Traceability'],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Flexible Authentication',
    body: 'Ship with TOTP two-factor authentication out of the box. Connect to your existing identity provider via LDAP, OAuth2, or SAML2. Padduck fits into your auth stack rather than forcing a new one.',
    tags: ['TOTP 2FA', 'LDAP', 'OAuth2 / SAML2'],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Fine-grained RBAC',
    body: 'Control exactly who can view and modify which sections of your address space. Delegate subnet management to teams without giving blanket admin access — scoped permissions that scale with your organisation.',
    tags: ['Roles', 'Scoped permissions', 'Delegation'],
  },
];
---
<section class="section features-section" id="features">
  <div class="container">
    <div class="features-header">
      <p class="eyebrow">Features</p>
      <h2 class="features-title">Everything you need to manage your IP space.</h2>
      <p class="features-sub">
        Built for the full lifecycle — not just address allocation.
      </p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <article class="feat-card card">
          <div class="feat-icon" aria-hidden="true">
            <Fragment set:html={f.icon} />
          </div>
          <h3 class="feat-title">{f.title}</h3>
          <p class="feat-body">{f.body}</p>
          <div class="feat-tags">
            {f.tags.map(t => <span class="feat-tag">{t}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.features-section {
  background: linear-gradient(180deg, #020812 0%, rgba(7, 22, 43, 0.4) 50%, #020812 100%);
}

.features-header {
  text-align: center;
  max-width: 580px;
  margin: 0 auto 64px;
}
.features-title {
  font-size: clamp(1.9rem, 4vw, 3rem);
  margin-block: 16px 16px;
}
.features-sub {
  color: var(--muted);
  font-size: 1.1rem;
}

/* Grid */
.features-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.feat-card {
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.feat-icon {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border-radius: var(--r-md);
  background: var(--gold-dim);
  border: 1px solid rgba(245, 184, 0, 0.18);
  color: var(--gold);
  flex-shrink: 0;
  transition: background 0.2s;
}
.feat-card:hover .feat-icon {
  background: rgba(245, 184, 0, 0.18);
}

.feat-title {
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.25;
}

.feat-body {
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.7;
  flex: 1;
}

.feat-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 4px;
}
.feat-tag {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--muted-2);
  background: rgba(244, 247, 250, 0.05);
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 3px 10px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

@media (max-width: 1100px) {
  .features-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 560px) {
  .features-grid { grid-template-columns: 1fr; }
}
</style>
