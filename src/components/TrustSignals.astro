---
interface Props {
  latestRelease: string | null;
  commitCount: string | null;
}
const { latestRelease, commitCount } = Astro.props;
const GITHUB = 'https://github.com/lima3w/padduck';

const stats = [
  { value: latestRelease ?? '—', label: 'Latest release',  link: `${GITHUB}/releases/latest`,  githubKey: 'release' },
  { value: commitCount   ?? '—', label: 'Commits on main', link: `${GITHUB}/commits/main`,      githubKey: 'commits' },
  { value: 'GPL-3.0',            label: 'Open source',     link: `${GITHUB}/blob/main/LICENSE`, githubKey: null      },
  { value: 'Go + React',         label: 'Tech stack',      link: null,                          githubKey: null      },
  { value: 'PostgreSQL',         label: 'Data store',      link: null,                          githubKey: null      },
];
---
<section class="section trust-section" aria-label="Project stats and trust signals">
  <div class="container">
    <div class="trust-inner">
      <div class="trust-text">
        <p class="eyebrow">Actively maintained</p>
        <h2 class="trust-title">Built in the open.<br />Shipped regularly.</h2>
        <p class="trust-body">
          Padduck is under active development. The changelog grows every release,
          the API is versioned and stable, and the issue tracker is public.
          You can see exactly where the project is headed.
        </p>
        <div class="trust-actions">
          <a href={GITHUB} class="btn btn-outline" target="_blank" rel="noopener noreferrer">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.579.688.481C19.138 20.2 22 16.447 22 12.021 22 6.484 17.522 2 12 2z"/>
            </svg>
            Star on GitHub
          </a>
          <a href={`${GITHUB}/wiki/Changelog`} class="btn btn-ghost" target="_blank" rel="noopener noreferrer">
            View Changelog →
          </a>
        </div>
      </div>

      <div class="trust-stats-col">
        {stats.map(s => (
          <div class="trust-stat card">
            {s.link
              ? <a href={s.link} target="_blank" rel="noopener noreferrer" class="trust-stat-link">
                  <span class="trust-val" data-github={s.githubKey ?? undefined}>{s.value}</span>
                  <span class="trust-lbl">{s.label}</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="trust-ext" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              : <div class="trust-stat-plain">
                  <span class="trust-val" data-github={s.githubKey ?? undefined}>{s.value}</span>
                  <span class="trust-lbl">{s.label}</span>
                </div>
            }
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.trust-section {
  background:
    radial-gradient(circle at 90% 50%, rgba(245, 184, 0, 0.07), transparent 50%),
    linear-gradient(180deg, #020812, rgba(7, 22, 43, 0.5), #020812);
}

.trust-inner {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: clamp(40px, 6vw, 100px);
  align-items: center;
}

.trust-title {
  font-size: clamp(1.9rem, 4vw, 3rem);
  margin-block: 16px 20px;
}
.trust-body {
  color: var(--muted);
  font-size: 1.05rem;
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: 36px;
}
.trust-actions { display: flex; flex-wrap: wrap; gap: 12px; }

/* Stats column */
.trust-stats-col {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.trust-stat {
  border-radius: var(--r-lg);
  padding: 18px 22px;
}

.trust-stat-link,
.trust-stat-plain {
  display: flex;
  align-items: center;
  gap: 12px;
}
.trust-stat-link {
  color: inherit;
  width: 100%;
}
.trust-stat-link:hover .trust-val { color: var(--gold); }

.trust-val {
  font-weight: 800;
  font-size: 1.1rem;
  color: var(--white);
  letter-spacing: -0.02em;
  transition: color 0.15s;
  min-width: 100px;
}
.trust-lbl {
  font-size: 0.85rem;
  color: var(--muted-2);
  flex: 1;
}
.trust-ext {
  color: var(--muted-2);
  flex-shrink: 0;
}

@media (max-width: 900px) {
  .trust-inner { grid-template-columns: 1fr; }
}
</style>
