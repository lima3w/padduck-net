---
const problems = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    label: 'The spreadsheet',
    title: 'Your IP spreadsheet is a liability.',
    body: 'No change history. No validation. No API. One bad paste creates hours of troubleshooting. Shared Google Sheets don\'t scale past a handful of subnets — and they certainly don\'t integrate with Terraform or Ansible.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
    label: 'phpIPAM',
    title: 'phpIPAM works — but it\'s showing its age.',
    body: 'The PHP codebase and dated UI weren\'t designed for teams that live in CI/CD pipelines. Automation through the API works, but it\'s not the primary experience. The UI can feel like it\'s from a different era of web development.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
    label: 'NetBox',
    title: 'NetBox is powerful — but not for everyone.',
    body: 'NetBox is an excellent network source of truth, but its complexity and operational overhead can be overkill for teams that just need solid IPAM. Network discovery and DNS integration require plugins and additional configuration.',
  },
];
---
<section class="section ps-section" id="problems">
  <div class="container">
    <div class="ps-header">
      <p class="eyebrow">The Problem</p>
      <h2 class="ps-title">Three problems every network team knows.</h2>
      <p class="ps-sub">
        Existing options make you choose between simplicity and power.
        Padduck closes that gap.
      </p>
    </div>

    <div class="ps-grid">
      {problems.map((p) => (
        <article class="ps-card card">
          <div class="ps-card-inner">
            <div class="ps-icon-wrap">
              <Fragment set:html={p.icon} />
            </div>
            <div class="ps-meta">
              <span class="ps-label">{p.label}</span>
              <h3 class="ps-card-title">{p.title}</h3>
              <p class="ps-card-body">{p.body}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Solution callout -->
    <div class="ps-solution">
      <div class="ps-solution-inner">
        <div class="ps-solution-badge badge">
          <span class="badge-dot"></span>
          The Padduck answer
        </div>
        <h3 class="ps-solution-title">
          Modern UI. API-first from day one.<br />
          Running in minutes, not days.
        </h3>
        <p class="ps-solution-body">
          Padduck is built with React and Go — a fast, clean interface backed
          by a stable REST API that was designed as the primary integration
          surface, not an afterthought. Deploy via Docker Compose, connect your
          existing workflows, and own all of your data in PostgreSQL.
        </p>
        <div class="ps-solution-pills">
          {['React UI', 'Go backend', 'PostgreSQL', 'REST API', 'Docker Compose', 'Self-hosted'].map(tag => (
            <span class="pill">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.ps-section {
  background:
    radial-gradient(circle at 80% 50%, rgba(93, 169, 233, 0.06), transparent 50%),
    linear-gradient(180deg, #020812 0%, var(--navy) 50%, #020812 100%);
}

.ps-header {
  text-align: center;
  max-width: 640px;
  margin: 0 auto 64px;
}

.ps-title {
  font-size: clamp(1.9rem, 4vw, 3rem);
  margin-block: 16px 18px;
}

.ps-sub {
  color: var(--muted);
  font-size: 1.1rem;
  line-height: 1.65;
}

/* Problem cards */
.ps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 56px;
}

.ps-card {
  padding: 32px;
}

.ps-card-inner {
  display: flex;
  flex-direction: column;
  gap: 20px;
  height: 100%;
}

.ps-icon-wrap {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: var(--r-md);
  background: rgba(244, 247, 250, 0.06);
  border: 1px solid var(--line-md);
  color: var(--muted);
  flex-shrink: 0;
}

.ps-meta { display: flex; flex-direction: column; gap: 8px; }

.ps-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted-2);
}

.ps-card-title {
  font-size: 1.05rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.25;
  color: var(--white);
}

.ps-card-body {
  color: var(--muted);
  font-size: 0.92rem;
  line-height: 1.7;
}

/* Solution callout */
.ps-solution {
  background: linear-gradient(135deg, rgba(10, 31, 58, 0.9), rgba(13, 40, 71, 0.7));
  border: 1px solid rgba(245, 184, 0, 0.20);
  border-radius: var(--r-2xl);
  overflow: hidden;
  position: relative;
}

.ps-solution::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 10% 50%, rgba(245, 184, 0, 0.08), transparent 60%);
  pointer-events: none;
}

.ps-solution-inner {
  position: relative;
  padding: clamp(36px, 5vw, 64px);
  max-width: 760px;
}

.ps-solution-badge { margin-bottom: 28px; }

.ps-solution-title {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  margin-bottom: 20px;
  line-height: 1.2;
}

.ps-solution-body {
  color: var(--muted);
  font-size: 1.05rem;
  line-height: 1.7;
  max-width: 640px;
  margin-bottom: 32px;
}

.ps-solution-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.pill {
  padding: 7px 14px;
  border: 1px solid var(--line-md);
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--white);
  background: rgba(244, 247, 250, 0.05);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

@media (max-width: 900px) {
  .ps-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .ps-grid { grid-template-columns: 1fr; }
}
</style>
