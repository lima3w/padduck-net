---
const GITHUB  = 'https://github.com/lima3w/padduck';
const WIKI    = 'https://github.com/lima3w/padduck/wiki';
const INSTALL = 'https://github.com/lima3w/padduck/wiki/Installation-Guide';
const ISSUES  = 'https://github.com/lima3w/padduck/issues';
const LICENSE = 'https://github.com/lima3w/padduck/blob/main/LICENSE';

const currentYear = new Date().getFullYear();
---
<!-- CTA band -->
<section class="cta-band" aria-label="Call to action">
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="cta-grid-bg" aria-hidden="true"></div>

  <div class="container cta-inner">
    <h2 class="cta-title">
      Ready to replace<br />
      <span class="cta-accent">the spreadsheet?</span>
    </h2>
    <p class="cta-sub">
      Deploy Padduck in two commands. No cloud account, no vendor lock-in,
      no enterprise pricing. Your infrastructure, your data.
    </p>
    <div class="cta-actions">
      <a href={INSTALL} class="btn btn-primary btn-lg" target="_blank" rel="noopener noreferrer">
        Get Started
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href={GITHUB} class="btn btn-outline btn-lg" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.579.688.481C19.138 20.2 22 16.447 22 12.021 22 6.484 17.522 2 12 2z"/>
        </svg>
        Star on GitHub
      </a>
      <a href={WIKI} class="btn btn-ghost btn-lg" target="_blank" rel="noopener noreferrer">
        Read the Docs →
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <circle cx="14" cy="14" r="13" fill="rgba(245,184,0,0.12)" stroke="#f5b800" stroke-width="1.5"/>
        <circle cx="14" cy="12" r="5" fill="#f5b800"/>
        <ellipse cx="14" cy="20" rx="8" ry="5" fill="#f5b800" opacity="0.7"/>
        <circle cx="16.5" cy="10.5" r="1" fill="#07162b"/>
      </svg>
      <span class="footer-wordmark">Padduck</span>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href={INSTALL} target="_blank" rel="noopener noreferrer">Install</a>
      <a href={WIKI} target="_blank" rel="noopener noreferrer">Docs</a>
      <a href={`${GITHUB}/wiki/Changelog`} target="_blank" rel="noopener noreferrer">Changelog</a>
      <a href={ISSUES} target="_blank" rel="noopener noreferrer">Issues</a>
      <a href={LICENSE} target="_blank" rel="noopener noreferrer">GPL-3.0</a>
      <a href={GITHUB} target="_blank" rel="noopener noreferrer">GitHub</a>
    </nav>

    <p class="footer-copy">
      © {currentYear} Padduck contributors. Released under GPL-3.0.
    </p>
  </div>
</footer>

<style>
/* ── CTA band ───────────────────────────────────────────────── */
.cta-band {
  position: relative;
  padding-block: clamp(80px, 12vw, 140px);
  overflow: hidden;
  text-align: center;
  background: linear-gradient(180deg, #020812, var(--navy-2));
}

.cta-glow {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 900px;
  height: 600px;
  background: radial-gradient(ellipse, rgba(245, 184, 0, 0.16) 0%, transparent 65%);
  pointer-events: none;
}

.cta-grid-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(244, 247, 250, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(244, 247, 250, 0.03) 1px, transparent 1px);
  background-size: 44px 44px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 0%, transparent 100%);
}

.cta-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cta-title {
  font-size: clamp(2.4rem, 6vw, 5rem);
  letter-spacing: -0.05em;
  line-height: 1.05;
  margin-bottom: 24px;
}

.cta-accent { color: var(--gold); }

.cta-sub {
  max-width: 560px;
  color: var(--muted);
  font-size: clamp(1rem, 2vw, 1.2rem);
  line-height: 1.65;
  margin-bottom: 48px;
}

.cta-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}

/* ── Footer ─────────────────────────────────────────────────── */
.site-footer {
  background: rgba(2, 8, 18, 0.95);
  border-top: 1px solid var(--line);
  padding-block: 36px;
}

.footer-inner {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 24px;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}
.footer-wordmark {
  font-weight: 800;
  font-size: 0.95rem;
  letter-spacing: -0.02em;
}

.footer-links {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  flex: 1;
}
.footer-links a {
  padding: 5px 10px;
  border-radius: var(--r-sm);
  color: var(--muted-2);
  font-size: 0.85rem;
  font-weight: 500;
  transition: color 0.15s;
}
.footer-links a:hover { color: var(--white); }

.footer-copy {
  color: var(--muted-2);
  font-size: 0.8rem;
  margin-left: auto;
}

@media (max-width: 640px) {
  .footer-inner { flex-direction: column; align-items: flex-start; }
  .footer-copy { margin-left: 0; }
  .cta-actions { flex-direction: column; align-items: stretch; }
  .cta-actions .btn { justify-content: center; }
}
</style>
