---
interface Props {
  latestRelease: string | null;
  commitCount: string | null;
}
const { latestRelease, commitCount } = Astro.props;
const GITHUB  = 'https://github.com/lima3w/padduck';
const DOCS    = 'https://github.com/lima3w/padduck/wiki';
const INSTALL = 'https://github.com/lima3w/padduck/wiki/Installation-Guide';
---
<section class="hero" aria-labelledby="hero-headline">
  <!-- Gradient glow orbs -->
  <div class="hero-glow hero-glow-1" aria-hidden="true"></div>
  <div class="hero-glow hero-glow-2" aria-hidden="true"></div>

  <!-- Grid overlay -->
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="container hero-content">
    <!-- Badge -->
    <div class="badge hero-badge">
      <span class="badge-dot"></span>
      Public Beta &nbsp;·&nbsp; <span data-github="release">{latestRelease ?? '—'}</span> released
    </div>

    <!-- Headline -->
    <h1 id="hero-headline" class="hero-h1">
      The IPAM your team<br />
      <span class="hero-accent">actually wants to use.</span>
    </h1>

    <!-- Sub-headline -->
    <p class="hero-lede">
      Padduck is a self-hosted, API-first IP address management platform.
      Replace spreadsheets and aging tools with structured, discoverable,
      automatable IP management — deployed in two commands.
    </p>

    <!-- CTAs -->
    <div class="hero-actions">
      <a href={INSTALL} class="btn btn-primary btn-lg" target="_blank" rel="noopener noreferrer">
        Get Started
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href={GITHUB} class="btn btn-outline btn-lg" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.579.688.481C19.138 20.2 22 16.447 22 12.021 22 6.484 17.522 2 12 2z"/>
        </svg>
        View on GitHub
      </a>
      <a href={DOCS} class="btn btn-ghost btn-lg" target="_blank" rel="noopener noreferrer">
        Read the Docs
      </a>
    </div>

    <!-- Quick-stat strip -->
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value" data-github="release">{latestRelease ?? '—'}</span>
        <span class="stat-label">Latest release</span>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value" data-github="commits">{commitCount ?? '—'}</span>
        <span class="stat-label">Commits on main</span>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">GPL-3.0</span>
        <span class="stat-label">Open source</span>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">2 commands</span>
        <span class="stat-label">To deploy</span>
      </div>
    </div>

    <!-- Logo / visual -->
    <div class="hero-visual">
      <img
        src="/assets/padduck-logo-dark.png"
        alt="Padduck IPAM interface"
        class="hero-logo"
        width="900"
        height="auto"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  overflow: hidden;
  padding-block: clamp(80px, 14vw, 160px) clamp(72px, 10vw, 120px);
}

/* Glow orbs */
.hero-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.hero-glow-1 {
  top: -20%;
  left: 50%;
  transform: translateX(-50%);
  width: 900px;
  height: 600px;
  background: radial-gradient(ellipse, rgba(245, 184, 0, 0.14) 0%, transparent 70%);
}
.hero-glow-2 {
  top: 5%;
  left: -10%;
  width: 700px;
  height: 500px;
  background: radial-gradient(ellipse, rgba(93, 169, 233, 0.10) 0%, transparent 70%);
}

/* Grid overlay */
.hero-grid {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(244, 247, 250, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(244, 247, 250, 0.03) 1px, transparent 1px);
  background-size: 44px 44px;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 0%, transparent 100%);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-badge { margin-bottom: 32px; }

.hero-h1 {
  font-size: clamp(2.6rem, 7vw, 5.4rem);
  letter-spacing: -0.05em;
  line-height: 1.0;
  max-width: 860px;
  margin-bottom: 28px;
}

.hero-accent {
  color: var(--gold);
  display: block;
}

.hero-lede {
  max-width: 680px;
  color: var(--muted);
  font-size: clamp(1.05rem, 2vw, 1.3rem);
  line-height: 1.65;
  margin-bottom: 44px;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
  margin-bottom: 56px;
}

/* Stats strip */
.hero-stats {
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
  justify-content: center;
  padding: 20px 32px;
  background: rgba(10, 31, 58, 0.55);
  border: 1px solid var(--line-md);
  border-radius: var(--r-xl);
  backdrop-filter: blur(8px);
  margin-bottom: 64px;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.stat-value {
  font-weight: 800;
  font-size: 1.05rem;
  color: var(--white);
  letter-spacing: -0.02em;
}
.stat-label {
  font-size: 0.76rem;
  color: var(--muted-2);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.stat-sep {
  width: 1px;
  height: 36px;
  background: var(--line-md);
}

/* Visual / logo */
.hero-visual {
  width: 100%;
  max-width: 900px;
  padding: 6px;
  background: linear-gradient(160deg, rgba(10, 31, 58, 0.8), rgba(7, 22, 43, 0.5));
  border: 1px solid var(--line-md);
  border-radius: var(--r-2xl);
  box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(244, 247, 250, 0.04);
}

.hero-logo {
  display: block;
  width: 100%;
  height: auto;
  border-radius: calc(var(--r-2xl) - 6px);
}

@media (max-width: 600px) {
  .hero-actions { flex-direction: column; align-items: stretch; }
  .hero-actions .btn { justify-content: center; }
  .stat-sep { display: none; }
  .hero-stats { gap: 16px; }
}
</style>
